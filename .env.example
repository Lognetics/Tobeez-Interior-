# Copy to .env and fill in. Public RAG chat and text-to-image have keyless
# fallbacks. Premium room-photo editing and video generation require keys.

# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Supabase (real Postgres + Auth) ---
# Public defaults are committed so the live site works; override here to point
# at a different project. The publishable/anon key is safe to expose (RLS-protected).
# NEXT_PUBLIC_SUPABASE_URL="https://ryuedzhmpljlmaoveoef.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# --- Auth (when wiring NextAuth / Clerk) ---
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- AI ---
# The assistant retrieves current platform records before every answer (RAG).
# Public platform RAG + text-to-image can use the keyless open-model fallback.
# Add OpenAI for flagship chat, private workspace context, GPT Image 2, and edits.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.5
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_QUALITY=high
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# POLLINATIONS_MODEL=openai
# GPT Image 2 handles premium image generation + room-photo redesign.
# Google Veo 3.1 through Replicate handles real video generation.
# REPLICATE_API_TOKEN=
# REPLICATE_VIDEO_MODEL=google/veo-3.1
# GENERATION_SIGNING_SECRET=replace-with-a-long-random-secret
# STABILITY_API_KEY=

# --- Payments ---
# Paystack: public key is safe client-side; secret key is SERVER-ONLY.
# Add PAYSTACK_SECRET_KEY to your Vercel env vars (never commit it).
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
# PAYSTACK_SECRET_KEY=sk_test_...
# STRIPE_SECRET_KEY=

# --- Email (booking notifications via Resend; silent no-op without a key) ---
# Create a key at resend.com after verifying the tobeezinteriors.com domain.
# RESEND_API_KEY=
# EMAIL_FROM="TOBEEZ Interiors <bookings@tobeezinteriors.com>"
# ADMIN_NOTIFICATIONS_EMAIL=team@tobeezinteriors.com
# CONSULTANT_LEAD_EMAILS="d1:victory@example.com,d2:joy@example.com"
# TWILIO_AUTH_TOKEN=

# --- Storage (stubbed) ---
# CLOUDINARY_URL=

# Copy to .env and fill in. All third-party keys are optional in this
# stubbed build — the app runs fully without them.

# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Supabase (real Postgres + Auth) ---
# Public defaults are committed so the live site works; override here to point
# at a different project. The publishable/anon key is safe to expose (RLS-protected).
# NEXT_PUBLIC_SUPABASE_URL="https://ryuedzhmpljlmaoveoef.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# --- Auth (when wiring NextAuth / Clerk) ---
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- AI ---
# Text + image generation are REAL and KEYLESS by default (open model).
# Add a key below to upgrade to a premium, faster, more reliable model.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# POLLINATIONS_MODEL=openai
# Real VIDEO generation & pixel-perfect image editing need a provider key:
# REPLICATE_API_TOKEN=
# STABILITY_API_KEY=

# --- Payments ---
# Paystack: public key is safe client-side; secret key is SERVER-ONLY.
# Add PAYSTACK_SECRET_KEY to your Vercel env vars (never commit it).
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...
# PAYSTACK_SECRET_KEY=sk_test_...
# STRIPE_SECRET_KEY=

# --- Email / SMS (stubbed) ---
# RESEND_API_KEY=
# TWILIO_AUTH_TOKEN=

# --- Storage (stubbed) ---
# CLOUDINARY_URL=
